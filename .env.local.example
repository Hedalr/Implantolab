# Espace praticien — Supabase
# Créer un projet sur https://supabase.com puis récupérer les clés dans Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Optionnel — scripts admin uniquement, ne jamais exposer côté client
# Requis pour inviter des praticiens depuis /espace-praticien/admin/praticiens
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# URL publique du site (invitations e-mail Supabase, callbacks auth)
# NEXT_PUBLIC_SITE_URL=https://www.implantolab.fr

# Actualités Notion (optionnel — voir docs/notion-setup.md)
# NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_DATABASE_ID=12ab34cd56ef7890abcdef1234567890
