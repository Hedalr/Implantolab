# =============================================================================
# Espace praticien — Supabase
# =============================================================================
# Créer un projet sur https://supabase.com puis récupérer les clés dans
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Optionnel — scripts admin uniquement, ne jamais exposer côté client
# Requis pour inviter des praticiens depuis /espace-praticien/admin/praticiens
# ET pour l'ingestion WhatsApp (webhook labo) qui écrit avec bypass RLS.
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# URL publique du site (invitations e-mail Supabase, callbacks auth)
# NEXT_PUBLIC_SITE_URL=https://www.implantolab.fr

# =============================================================================
# Module Laboratoire — WhatsApp Business Cloud API
# =============================================================================
# Configuration Meta : https://developers.facebook.com/docs/whatsapp/cloud-api
#
# 1. Créer une app Meta type Business puis ajouter le produit "WhatsApp".
# 2. Récupérer les infos dans WhatsApp → API Setup.
# 3. Renseigner le webhook URL : https://<site>/api/whatsapp/webhook
#    et le verify token (celui défini ci-dessous).
# 4. S'abonner au champ `messages`.
# 5. Ajouter le numéro de téléphone Business dédié au labo.

# Token arbitraire choisi par vous, à saisir tel quel côté Meta Dashboard.
# WHATSAPP_VERIFY_TOKEN=implantolab-verify-xxxxxxxxx

# Secret d'application Meta (App Dashboard → Settings → Basic → App Secret).
# Utilisé pour vérifier la signature HMAC-SHA256 des webhooks entrants.
# WHATSAPP_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Access token permanent (System User) pour appeler la Graph API depuis le
# serveur, notamment pour télécharger les médias (media_id → binaire).
# WHATSAPP_ACCESS_TOKEN=EAAG...

# ID du numéro business (WhatsApp Manager → Phone Numbers → Phone number ID).
# Sert à envoyer des messages sortants (accusés de réception au dentiste).
# WHATSAPP_PHONE_NUMBER_ID=1234567890

# Version de l'API Graph. Meta recommande de fixer explicitement une version.
# WHATSAPP_API_VERSION=v21.0

# =============================================================================
# Module Laboratoire — Extraction IA
# =============================================================================
# Une seule des deux clés suffit. Si aucune n'est fournie, l'ingestion
# fonctionne mais crée les dossiers en `pending_review` avec extraction vide,
# à compléter à la main depuis l'admin.

# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

# =============================================================================
# Module Laboratoire — Notifications Slack (optionnel)
# =============================================================================
# Créer un Incoming Webhook dans Slack et coller l'URL ci-dessous.
# Une notification est envoyée à chaque nouveau dossier créé et à chaque
# ajout de pièce jointe.
# SLACK_WEBHOOK_URL=<your-slack-incoming-webhook-url>

# =============================================================================
# Actualités Notion (optionnel — voir docs/notion-setup.md)
# =============================================================================
# NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_DATABASE_ID=12ab34cd56ef7890abcdef1234567890

# =============================================================================
# Offres de recrutement Notion (optionnel — voir docs/notion-recrutement-setup.md)
# =============================================================================
# Réutilise le même NOTION_TOKEN que ci-dessus (même intégration Notion),
# avec une base dédiée aux offres d'emploi.
# NOTION_JOBS_DATABASE_ID=12ab34cd56ef7890abcdef1234567890
